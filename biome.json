{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "src/**/*.{ts,tsx}",
      "vite.config.ts",
      "package.json",
      "tsconfig*.json",
      "biome.json",
      ".devcontainer/**/*.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "rules": {
      "recommended": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.json", "**/*.jsonc", "tsconfig*.json", "biome.json"],
      "formatter": { "indentWidth": 2 }
    }
  ]
}
